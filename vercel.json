{
    "buildCommand": "vite build",
    "outputDirectory": "dist/public",
    "installCommand": "npm install",
    "functions": {
          "api/trpc/[trpc].ts": {
                  "maxDuration": 30
          }
    },
    "rewrites": [
          { "source": "/api/trpc/(.*)", "destination": "/api/trpc/$1" },
          { "source": "/((?!api/).*)", "destination": "/index.html" }
    ]
}
